generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model BidProject {
  id String @id @default(cuid())

  name         String
  client       String?
  unit         String?
  contractType String?
  status       String  @default("NOVO")

  responsibleName  String?
  proposalDeadline DateTime?

  paymentTermDays Int?
  capitalCostRate Float @default(1.5)

  mobilizationRequired Boolean @default(false)
  officeRequired       Boolean @default(false)
  workshopRequired     Boolean @default(false)
  containerRequired    Boolean @default(false)

  transportationScope String?
  mealsScope          String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions   BidQuestion[]
  assumptions BidAssumption[]
  risks       BidRisk[]
  outputs     BidOutput[]

  @@index([client])
  @@index([status])
  @@index([contractType])
}

model BidQuestion {
  id String @id @default(cuid())

  projectId String
  category  String?
  question  String
  answer    String?
  required  Boolean @default(true)

  createdAt DateTime @default(now())

  project BidProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model BidAssumption {
  id String @id @default(cuid())

  projectId   String
  title       String
  description String

  createdAt DateTime @default(now())

  project BidProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model BidRisk {
  id String @id @default(cuid())

  projectId String

  category    String?
  severity    String?
  description String
  mitigation  String?

  createdAt DateTime @default(now())

  project BidProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([severity])
}

model BidOutput {
  id String @id @default(cuid())

  projectId String

  outputType String
  content    String

  createdAt DateTime @default(now())

  project BidProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([outputType])
}

model BidDisclaimerAcceptance {
  id String @id @default(cuid())

  userEmail  String
  acceptedAt DateTime @default(now())

  lgpdAccepted  Boolean @default(false)
  termsAccepted Boolean @default(false)

  ipAddress String?

  @@index([userEmail])
}

model User {
  auditLogs AuditLog[]
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         String   @default("USER")
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt


  @@index([email])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  @@index([userId])
}

model VisitorSession {
  id        String   @id @default(cuid())
  visitorId String
  referrer  String?
  source    String?
  createdAt DateTime @default(now())
  pageViews PageView[]
  events    TrackingEvent[]
  @@index([visitorId])
}

model PageView {
  id        String          @id @default(cuid())
  sessionId String?
  path      String
  title     String?
  referrer  String?
  createdAt DateTime        @default(now())
  session   VisitorSession? @relation(fields: [sessionId], references: [id])
  @@index([sessionId])
}

model TrackingEvent {
  id        String          @id @default(cuid())
  sessionId String?
  eventName String
  path      String?
  metadata  Json?
  createdAt DateTime        @default(now())
  session   VisitorSession? @relation(fields: [sessionId], references: [id])
  @@index([sessionId])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  role      String?
  interest  String?
  message   String?
  source    String?  @default("site")
  status    String   @default("NOVO")
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([status])
}
