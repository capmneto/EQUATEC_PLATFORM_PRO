generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  GESTOR
  CLIENTE
  USER
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  password       String?
  image          String?
  role           UserRole  @default(USER)
  approved       Boolean   @default(false)
  company        String?
  phone          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  permissions    ModulePermission[]
  accessRequests AccessRequest[]
  auditLogs      AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ModulePermission {
  id         String   @id @default(cuid())
  userId     String
  moduleKey  String
  canView    Boolean  @default(false)
  canEdit    Boolean  @default(false)
  canApprove Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleKey])
  @@index([moduleKey])
}

model AccessRequest {
  id         String   @id @default(cuid())
  userId     String
  moduleKey  String
  reason     String?  @db.Text
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([moduleKey])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model VisitorSession {
  id        String   @id @default(cuid())
  visitorId String
  ipHash    String?
  userAgent String?  @db.Text
  referrer  String?  @db.Text
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pageViews PageView[]
  events    TrackingEvent[]

  @@index([visitorId])
  @@index([createdAt])
}

model PageView {
  id        String   @id @default(cuid())
  sessionId String?
  path      String
  title     String?
  referrer  String?  @db.Text
  createdAt DateTime @default(now())

  session VisitorSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([path])
  @@index([createdAt])
  @@index([sessionId])
}

model TrackingEvent {
  id        String   @id @default(cuid())
  sessionId String?
  eventName String
  path      String?
  metadata  Json?
  createdAt DateTime @default(now())

  session VisitorSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([eventName])
  @@index([path])
  @@index([createdAt])
  @@index([sessionId])
}


model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  role      String?
  interest  String?
  message   String?  @db.Text
  source    String?
  status    String   @default("NOVO")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([interest])
  @@index([createdAt])
}
